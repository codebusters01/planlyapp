<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Arc?>

<AnchorPane fx:id="root" prefHeight="852.0" prefWidth="393.0"
            style="-fx-background-color: #f7f5ef;"
            xmlns="http://javafx.com/javafx/25"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="HomeController">

    <children>

        <Pane prefHeight="185.0" prefWidth="393.0">
            <children>
                <Arc centerX="196.5"
                     centerY="0.0"
                     fill="#7aaacc"
                     length="180.0"
                     radiusX="196.5"
                     radiusY="185.0"
                     startAngle="180.0"
                     stroke="#8d8d8d"
                     type="ROUND" />

                <Label layoutX="96.0"
                       layoutY="41.0"
                       style="-fx-font-size: 70px; -fx-font-weight: bold; -fx-text-fill: white; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.3), 8, 0.2, 3, 3);"
                       text="Planly" />
            </children>
        </Pane>

        <Label layoutX="22.0"
               layoutY="192.0"
               prefHeight="40.0"
               prefWidth="200.0"
               style="-fx-font-size: 30px; -fx-font-weight: bold; -fx-text-fill: #6c9ec9;"
               text="Home" />

        <Label fx:id="welcomeLabel"
               layoutX="22.0"
               layoutY="235.0"
               prefHeight="25.0"
               prefWidth="350.0"
               style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: black;"
               text="Welcome Back!" />

        <Pane layoutX="22.0"
              layoutY="270.0"
              prefHeight="160.0"
              prefWidth="350.0"
              style="-fx-background-color: #d9eaf5; -fx-background-radius: 18; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.18), 10, 0.2, 0, 4);">

            <children>
                <Label layoutX="15.0"
                       layoutY="12.0"
                       style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #6c9ec9;"
                       text="🎯 High Priority" />

                <VBox fx:id="highTasksBox"
                      layoutX="15.0"
                      layoutY="45.0"
                      prefHeight="100.0"
                      prefWidth="320.0"
                      spacing="10.0" />
            </children>
        </Pane>

        <Pane layoutX="22.0"
              layoutY="445.0"
              prefHeight="250.0"
              prefWidth="350.0"
              style="-fx-background-color: #d9eaf5; -fx-background-radius: 18; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.18), 10, 0.2, 0, 4);">

            <children>
                <Label layoutX="15.0"
                       layoutY="12.0"
                       style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #6c9ec9;"
                       text="🎯 Today's Focus" />

                <VBox fx:id="todayTasksBox"
                      layoutX="15.0"
                      layoutY="45.0"
                      prefHeight="180.0"
                      prefWidth="320.0"
                      spacing="8.0" />
            </children>
        </Pane>

        <HBox alignment="CENTER"
              layoutY="787.0"
              prefHeight="65.0"
              prefWidth="393.0"
              spacing="15.0"
              style="-fx-background-color: white; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 5, 0, 0, -2);">

            <children>
                <Button contentDisplay="TOP"
                        prefHeight="55.0"
                        prefWidth="90.0"
                        text="Home"
                        mnemonicParsing="false"
                        style="-fx-background-color: #d9eaf5; -fx-text-fill: #2f5878; -fx-font-weight: bold; -fx-font-size: 12px; -fx-background-radius: 15;">
                    <graphic>
                        <ImageView fitHeight="24.0" fitWidth="24.0" preserveRatio="true">
                            <image>
                                <Image url="@images/home.png" />
                            </image>
                        </ImageView>
                    </graphic>
                </Button>

                <Button contentDisplay="TOP"
                        prefHeight="55.0"
                        prefWidth="90.0"
                        text="Tasks"
                        mnemonicParsing="false"
                        onAction="#handleTasks"
                        style="-fx-background-color: transparent; -fx-text-fill: #8d8d8d; -fx-font-weight: bold; -fx-font-size: 12px;">
                    <graphic>
                        <ImageView fitHeight="24.0" fitWidth="24.0" preserveRatio="true">
                            <image>
                                <Image url="@images/clock.png" />
                            </image>
                        </ImageView>
                    </graphic>
                </Button>

                <Button contentDisplay="TOP"
                        prefHeight="55.0"
                        prefWidth="90.0"
                        text="Settings"
                        mnemonicParsing="false"
                        onAction="#handleSettings"
                        style="-fx-background-color: transparent; -fx-text-fill: #8d8d8d; -fx-font-weight: bold; -fx-font-size: 12px;">
                    <graphic>
                        <ImageView fitHeight="24.0" fitWidth="24.0" preserveRatio="true">
                            <image>
                                <Image url="@images/settings.png" />
                            </image>
                        </ImageView>
                    </graphic>
                </Button>
            </children>
        </HBox>

    </children>
</AnchorPane>