<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ToggleButton?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.shape.Arc?>

<AnchorPane fx:id="root" prefHeight="852.0" prefWidth="393.0"
            style="-fx-background-color: #f7f5ef;"
            xmlns="http://javafx.com/javafx/25"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="SettingsController">

    <children>

        <Pane prefHeight="185.0" prefWidth="393.0">
            <children>
                <Arc centerX="196.5"
                     centerY="0.0"
                     fill="#7aaacc"
                     length="180.0"
                     radiusX="196.5"
                     radiusY="185.0"
                     startAngle="180.0"
                     stroke="#8d8d8d"
                     type="ROUND" />

                <Label layoutX="96.0"
                       layoutY="41.0"
                       style="-fx-font-size: 70px; -fx-font-weight: bold; -fx-text-fill: white; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.3), 8, 0.2, 3, 3);"
                       text="Planly" />
            </children>
        </Pane>

        <Label layoutX="22.0"
               layoutY="192.0"
               prefHeight="58.0"
               prefWidth="200.0"
               style="-fx-font-size: 30px; -fx-font-weight: bold; -fx-text-fill: #6c9ec9;"
               text="Settings" />

        <Pane layoutX="22.0"
              layoutY="250.0"
              prefHeight="500.0"
              prefWidth="350.0"
              style="-fx-background-color: #d9eaf5; -fx-background-radius: 18; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.18), 10, 0.2, 0, 4);">

            <children>
                <Label layoutX="35.0"
                       layoutY="35.0"
                       style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #6c9ec9;"
                       text="Appearance" />

                <ToggleButton fx:id="darkModeToggle"
                              layoutX="35.0"
                              layoutY="75.0"
                              mnemonicParsing="false"
                              onAction="#handleDarkModeToggle"
                              prefHeight="56.0"
                              prefWidth="280.0"
                              style="-fx-background-color: white; -fx-text-fill: #2f5878; -fx-font-size: 15px; -fx-background-radius: 10; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.3), 8, 0.2, 3, 3); -fx-cursor: hand;"
                              text="Dark Mode" />

                <Label layoutX="35.0"
                       layoutY="165.0"
                       style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #6c9ec9;"
                       text="Account" />

                <Button layoutX="35.0"
                        layoutY="205.0"
                        mnemonicParsing="false"
                        onAction="#handleLogOut"
                        prefHeight="56.0"
                        prefWidth="280.0"
                        style="-fx-background-color: #2f5878; -fx-text-fill: white; -fx-font-size: 15px; -fx-background-radius: 10; -fx-cursor: hand;"
                        text="Log Out" />
            </children>
        </Pane>

        <HBox alignment="CENTER"
              layoutY="787.0"
              prefHeight="65.0"
              prefWidth="393.0"
              spacing="15.0"
              style="-fx-background-color: white; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 5, 0, 0, -2);">

            <children>
                <Button contentDisplay="TOP"
                        mnemonicParsing="false"
                        onAction="#handleHome"
                        prefHeight="55.0"
                        prefWidth="90.0"
                        style="-fx-background-color: transparent; -fx-text-fill: #8d8d8d; -fx-font-weight: bold; -fx-font-size: 12px;"
                        text="Home">
                    <graphic>
                        <ImageView fitHeight="24.0" fitWidth="24.0" preserveRatio="true">
                            <image>
                                <Image url="@images/home.png" />
                            </image>
                        </ImageView>
                    </graphic>
                </Button>

                <Button contentDisplay="TOP"
                        mnemonicParsing="false"
                        onAction="#handleTasks"
                        prefHeight="55.0"
                        prefWidth="90.0"
                        style="-fx-background-color: transparent; -fx-text-fill: #8d8d8d; -fx-font-weight: bold; -fx-font-size: 12px;"
                        text="Tasks">
                    <graphic>
                        <ImageView fitHeight="24.0" fitWidth="24.0" preserveRatio="true">
                            <image>
                                <Image url="@images/clock.png" />
                            </image>
                        </ImageView>
                    </graphic>
                </Button>

                <Button contentDisplay="TOP"
                        mnemonicParsing="false"
                        onAction="#handleSettings"
                        prefHeight="55.0"
                        prefWidth="90.0"
                        style="-fx-background-color: #d9eaf5; -fx-text-fill: #2f5878; -fx-font-weight: bold; -fx-font-size: 12px; -fx-background-radius: 15;"
                        text="Settings">
                    <graphic>
                        <ImageView fitHeight="24.0" fitWidth="24.0" preserveRatio="true">
                            <image>
                                <Image url="@images/settings.png" />
                            </image>
                        </ImageView>
                    </graphic>
                </Button>
            </children>
        </HBox>

    </children>
</AnchorPane>